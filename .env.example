# ── دیتابیس (نئون پستگرس) ──────────────────────────────────────────────
# بعد از ساخت پروژه در https://neon.tech دو مقدار زیر را از پنل نئون بردار:
# DATABASE_URL: connection string با pooling (برای اجرای عادی برنامه)
# DIRECT_URL:   connection string مستقیم بدون pooling (برای prisma migrate)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# ── next-auth ───────────────────────────────────────────────────────────
# یک رشته تصادفی امن بساز: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ── uploadthing ─────────────────────────────────────────────────────────
# از https://uploadthing.com پس از ساخت اپ، توکن را بردار
UPLOADTHING_TOKEN=""

# ── زرین‌پال ────────────────────────────────────────────────────────────
# از پنل https://next.zarinpal.com مرچنت‌کد را بگیر
ZARINPAL_MERCHANT_ID=""
# false برای محیط پروداکشن، true برای تست با sandbox
ZARINPAL_SANDBOX="true"

# ── عمومی ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── BrsApi (قیمت لحظه‌ای طلا) ───────────────────────────────────────────
# یک کلید رایگان از https://brsapi.ir بگیر (پلن رایگان تا ۱۵۰۰ ریکوئست در روز)
BRSAPI_API_KEY=""
